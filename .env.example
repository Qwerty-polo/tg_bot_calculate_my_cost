# ─── Telegram ───────────────────────────────────────────────
# Get a token from @BotFather
BOT_TOKEN=123456:your-telegram-bot-token

# ─── OpenAI ─────────────────────────────────────────────────
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_MODEL=gpt-4o-mini

# ─── Database ───────────────────────────────────────────────
# Async SQLAlchemy URL. Default is a local SQLite file.
DATABASE_URL=sqlite+aiosqlite:///./data/expenses.db

# ─── OCR ────────────────────────────────────────────────────
# Engine: "tesseract" (default, lightweight) or "easyocr" (heavier, needs torch)
OCR_ENGINE=tesseract
# Languages for OCR. Tesseract: "eng+ukr". EasyOCR: "en,uk"
OCR_LANGUAGES=eng+ukr

# ─── App ────────────────────────────────────────────────────
DEFAULT_CURRENCY=UAH
LOG_LEVEL=INFO
# Comma-separated list of telegram user ids allowed to use the bot.
# Leave empty to allow everyone.
ALLOWED_USER_IDS=
