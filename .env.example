# ─── Telegram ───────────────────────────────────────────────
# Get a token from @BotFather
BOT_TOKEN=123456:your-telegram-bot-token

# ─── Google Gemini (AI) ─────────────────────────────────────
# Gemini is the only supported LLM provider. It is called via Google's
# OpenAI-compatible endpoint. Get a key at https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-3.1-flash-lite

# ─── Database ───────────────────────────────────────────────
# Async SQLAlchemy URL. Default is a local SQLite file.
DATABASE_URL=sqlite+aiosqlite:///./data/expenses.db

# ─── OCR ────────────────────────────────────────────────────
# Engine: "tesseract" (default, lightweight) or "easyocr" (heavier, needs torch)
OCR_ENGINE=tesseract
# Languages for OCR. Tesseract: "eng+ukr". EasyOCR: "en,uk"
OCR_LANGUAGES=eng+ukr
# Path to the tesseract binary. Leave empty to use the one on PATH
# (Linux/macOS/CI/Docker). On Windows, point it at your install, e.g.
# TESSERACT_CMD=C:\Program Files\Tesseract-OCR\tesseract.exe
TESSERACT_CMD=

# ─── App ────────────────────────────────────────────────────
# Currency is always UAH (hardcoded) and not configurable.
LOG_LEVEL=INFO
# Comma-separated list of telegram user ids allowed to use the bot.
# Leave empty to allow everyone.
ALLOWED_USER_IDS=
